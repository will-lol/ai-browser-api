{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "exclude": ["duplicates"],
  "tags": ["-lintignore"],
  "workspaces": {
    ".": {},
    "packages/bridge-codecs": {
      "entry": ["src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/client": {
      "entry": ["src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/contracts": {
      "entry": ["src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/extension": {
      "entry": [
        "src/entrypoints/background/index.ts",
        "src/entrypoints/content/index.tsx",
        "src/entrypoints/connect/main.tsx",
        "src/entrypoints/popup/main.tsx",
        "src/**/*.test.ts",
        "scripts/**/*.ts",
        "web-ext.config.ts",
        "wxt.config.ts"
      ],
      "ignore": ["src/entrypoints/popup/routeTree.gen.ts"],
      "project": [
        "src/**/*.{ts,tsx}",
        "scripts/**/*.ts",
        "src/styles/**/*.css",
        "*.config.{js,mjs,ts}"
      ]
    },
    "packages/runtime-core": {
      "entry": ["src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/runtime-events": {
      "entry": ["src/**/*.test.ts"],
      "project": ["src/**/*.ts"]
    }
  }
}
