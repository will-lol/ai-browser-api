{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "jsx": "react-jsx",
    "isolatedModules": true,
    "allowJs": false
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "scripts/**/*.ts",
    "web-ext.config.ts",
    "wxt.config.ts"
  ],
  "exclude": ["node_modules", ".wxt", ".output"]
}
